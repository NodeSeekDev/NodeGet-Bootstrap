{
    "name":"server-task-worker",
    "crons":[
        {
            "name":"periodic-cleanup",
            "cron_expression":"0 0 * * * *",
            "cron_type": {
                "server":{
                    "js_worker":[
                        "server-task-worker",
                        {
                            "task": {
                                "name": "clean_up_database"
                            }
                        }
                    ]
                }
            }
        }
    ],
    "env":{
        "disable_auto_update":"false"
    },
    "config":{
        "runtime_clean_time":600000,
        "max_run_time":600000
    },
    "route_name":"$random"
}