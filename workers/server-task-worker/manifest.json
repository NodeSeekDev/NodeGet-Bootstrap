{
    "name":"server-task-worker",
    "crons":[
        {
            "name":"periodic-cleanup",
            "cron_expression":"0 0 * * * *",
            "cron_type": {
                "server":{
                    "js_worker":[
                        "server-task-worker",
                        {
                            "task": "clean_up_database"
                        }
                    ]
                }
            }
        }
    ],
    "env":{
        "disable_auto_update":"false"
    },
    "route_name":"$random"
}