{
    "name":"base-worker",
    "crons":[
        {
            "name":"base-worker-update",
            "cron_expression":"0 0 * * * *",
            "cron_type": {
                "server":{
                    "js_worker":[
                        "base-worker",
                        {
                            "task": "update"
                        }
                    ]
                }
            }
        }
    ],
    "env":{
        "resource_url":"",
        "disable_auto_update":"false"
    },
    "config":{
        "runtime_clean_time":300000,
        "max_run_time":300000
    },
    "route_name":"$random"
}